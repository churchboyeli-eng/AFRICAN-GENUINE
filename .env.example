# ── WhatsApp Click-to-chat (safe to expose) ──────────────────────────────────
# Your WhatsApp Business number — international format, no + or spaces
NEXT_PUBLIC_WHATSAPP_NUMBER=255XXXXXXXXX
# Pre-filled message for the floating chat button
NEXT_PUBLIC_WHATSAPP_DEFAULT_MSG=Hi African Genuine Tours & Safaris, I'd like to enquire about a Tanzania safari.

# ── WhatsApp Business Cloud API (SERVER-ONLY — never prefix with NEXT_PUBLIC_) ─
# Meta for Developers → Your App → WhatsApp → API Setup
WHATSAPP_CLOUD_TOKEN=           # Permanent system-user token (not the 24h temp token)
WHATSAPP_PHONE_NUMBER_ID=       # Numeric Phone Number ID shown on the API Setup page
WHATSAPP_BUSINESS_ACCOUNT_ID=   # WhatsApp Business Account ID
WHATSAPP_VERIFY_TOKEN=          # Any random string — used for Meta webhook verification
WHATSAPP_APP_SECRET=            # App Dashboard → Settings → Basic → App Secret
# Number that receives new-enquiry notifications (can match NEXT_PUBLIC_WHATSAPP_NUMBER)
WHATSAPP_TEAM_NUMBER=255XXXXXXXXX
